{
  "manifest_version": 3,
  "name": "Chess Realtime Assistant",
  "version": "1.0.0",
  "description": "Real-time chess analysis powered by Stockfish engine. Reads board state from Chess.com and Lichess.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://lichess.org/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Chess Realtime Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*", "https://lichess.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
